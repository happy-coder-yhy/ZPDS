{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zpds.dev/schemas/release.schema.json",
  "title": "ZPDS Release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "zpds_version",
    "release_id",
    "dataset_id",
    "dataset_version",
    "prep_revision",
    "annotation_version",
    "created_at",
    "selection",
    "splits"
  ],
  "properties": {
    "zpds_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "release_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "dataset_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "prep_revision": {
      "type": "string",
      "pattern": "^r\\d{4,}$"
    },
    "annotation_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "only_training_usable",
        "allowed_outcomes"
      ],
      "properties": {
        "only_training_usable": {
          "type": "boolean"
        },
        "allowed_outcomes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "success",
              "failure",
              "partial",
              "unknown"
            ]
          }
        }
      }
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "train",
        "validation",
        "test"
      ],
      "properties": {
        "train": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+"
        },
        "validation": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+"
        },
        "test": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+"
        }
      }
    }
  }
}
