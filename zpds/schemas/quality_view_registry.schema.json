{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zpds.dev/schemas/quality_view_registry.schema.json",
  "title": "ZPDS Quality View Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "zpds_version", "metrics", "views"],
  "properties": {
    "registry_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "zpds_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "direction", "description"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "direction": {
            "enum": ["higher_is_better", "lower_is_better", "in_range"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "view_id",
          "version",
          "description",
          "required_metrics",
          "optional_metrics",
          "blocking_decisions"
        ],
        "properties": {
          "view_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "required_metrics": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "optional_metrics": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "blocking_decisions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["quarantine", "reject"]
            }
          }
        }
      }
    }
  }
}
