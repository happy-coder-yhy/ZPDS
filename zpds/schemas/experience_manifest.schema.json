{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zpds.dev/schemas/experience_manifest.schema.json",
  "title": "ZPDS Experience Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "zpds_version",
    "prep_revision",
    "experience_version",
    "created_at",
    "status",
    "producers",
    "asset_roots"
  ],
  "properties": {
    "zpds_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "prep_revision": {
      "type": "string",
      "pattern": "^r\\d{4,}$"
    },
    "experience_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "released"
      ]
    },
    "producers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "producer_id",
          "kind",
          "name",
          "version",
          "config_hash"
        ],
        "properties": {
          "producer_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "model",
              "human",
              "deterministic"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "config_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "asset_roots": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+"
      }
    }
  }
}
