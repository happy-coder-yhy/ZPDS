{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zpds.dev/schemas/run_ledger.schema.json",
  "title": "ZPDS Pipeline Run Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "zpds_version",
    "run_id",
    "session_id",
    "config_hash",
    "code_version",
    "input_refs",
    "status",
    "created_at",
    "updated_at",
    "stages"
  ],
  "properties": {
    "zpds_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "config_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "code_version": {
      "type": "string",
      "minLength": 1
    },
    "input_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    }
  },
  "$defs": {
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "name",
        "version"
      ],
      "properties": {
        "stage_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 12
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor",
        "execution_key",
        "status",
        "attempts",
        "input_refs",
        "output_refs",
        "started_at",
        "finished_at",
        "last_error",
        "result"
      ],
      "properties": {
        "descriptor": {
          "$ref": "#/$defs/descriptor"
        },
        "execution_key": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "status": {
          "enum": [
            "pending",
            "running",
            "succeeded",
            "failed",
            "skipped"
          ]
        },
        "attempts": {
          "type": "integer",
          "minimum": 0
        },
        "input_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "result": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/result"
            }
          ]
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor",
        "status",
        "input_refs",
        "output_refs",
        "config_hash",
        "started_at",
        "finished_at",
        "metrics",
        "decisions",
        "evidence",
        "error"
      ],
      "properties": {
        "descriptor": {
          "$ref": "#/$defs/descriptor"
        },
        "status": {
          "enum": [
            "succeeded",
            "failed",
            "skipped"
          ]
        },
        "input_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "config_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
